rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Perfis: leitura por logados (para exibir nomes no ranking).
    match /users/{uid} {
      allow read: if signedIn();
      // cria o próprio doc e NÃO pode se auto-promover a admin
      allow create: if signedIn() && request.auth.uid == uid
                    && request.resource.data.isAdmin == false;
      // atualiza o próprio doc sem mexer no isAdmin
      allow update: if signedIn() && request.auth.uid == uid
                    && request.resource.data.isAdmin == resource.data.isAdmin;
      allow delete: if false;
    }

    // Jogos: todos os logados leem. Escrita só por admin.
    // (O sincronizador usa o Admin SDK, que ignora estas regras — ok.)
    match /matches/{matchId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Ranking pré-calculado pelo sincronizador (1 doc: rankings/current).
    // Logados leem; ninguém escreve pelo client (só o Admin SDK do sync).
    match /rankings/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Snapshot dos jogos (1 doc: snapshots/matches) — o app lê esse doc em vez
    // de varrer a coleção `matches` (104 leituras). Logados leem; só o sync escreve.
    match /snapshots/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Palpites: leitura por logados (o ranking precisa somar todos).
    // Criação: só o dono, dados válidos, em QUALQUER jogo (inclusive os que já
    // aconteceram — os palpites foram feitos antes, no papel).
    // Write-once: depois de enviado NÃO pode editar nem apagar.
    match /predictions/{predId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.uid
        && predId == request.auth.uid + '_' + request.resource.data.matchId
        && request.resource.data.keys().hasOnly(['uid', 'matchId', 'homeScore', 'awayScore', 'updatedAt'])
        && request.resource.data.homeScore is int && request.resource.data.homeScore >= 0 && request.resource.data.homeScore <= 99
        && request.resource.data.awayScore is int && request.resource.data.awayScore >= 0 && request.resource.data.awayScore <= 99
        // jogos de abertura têm palpite bloqueado (México x Áf. do Sul / Coreia x Tcheca)
        && !(request.resource.data.matchId in ['537327', '537328']);
      allow update, delete: if false;
    }

    // Palpites do mata-mata (chaveamento montado pelo próprio usuário). Nos
    // 16-avos ele escolhe as duas seleções (homeTeam/awayTeam); das oitavas em
    // diante os times saem em cascata. Write-once, como os palpites de grupo.
    match /koPredictions/{predId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.uid
        && predId == request.auth.uid + '_' + string(request.resource.data.matchNum)
        && request.resource.data.keys().hasAll(['uid', 'matchNum', 'homeScore', 'awayScore', 'winner', 'updatedAt'])
        && request.resource.data.keys().hasOnly(['uid', 'matchNum', 'homeScore', 'awayScore', 'winner', 'homeTeam', 'awayTeam', 'updatedAt'])
        && request.resource.data.matchNum is int && request.resource.data.matchNum >= 73 && request.resource.data.matchNum <= 104
        && request.resource.data.homeScore is int && request.resource.data.homeScore >= 0 && request.resource.data.homeScore <= 99
        && request.resource.data.awayScore is int && request.resource.data.awayScore >= 0 && request.resource.data.awayScore <= 99
        && request.resource.data.winner in ['home', 'away']
        && (!('homeTeam' in request.resource.data) || (request.resource.data.homeTeam is string && request.resource.data.homeTeam.size() > 0 && request.resource.data.homeTeam.size() <= 60))
        && (!('awayTeam' in request.resource.data) || (request.resource.data.awayTeam is string && request.resource.data.awayTeam.size() > 0 && request.resource.data.awayTeam.size() <= 60));
      allow update, delete: if false;
    }
  }
}
